{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/includes/(.*)", "dest": "/includes/$1" },
    { "src": "/(.*\\.php)", "dest": "/$1" },
    { "src": "/", "dest": "/index.php" }
  ],
  "regions": ["sin1"]
}