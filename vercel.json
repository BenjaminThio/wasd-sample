{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "^/api/includes/.*\\.php$",
      "dest": "/404"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(?!api/)(.*)\\.php$",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    }
  ]
}